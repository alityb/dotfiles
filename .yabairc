#!/usr/bin/env sh

# Scripting addition (uncomment if you have sudo configured for yabai)
# yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
# sudo yabai --load-sa

# Global settings
yabai -m config                                \
    external_bar                 all:42:0      \
    menubar_opacity              1.0           \
    mouse_follows_focus          off           \
    focus_follows_mouse          off           \
    display_arrangement_order    default       \
    window_origin_display        default       \
    window_placement             second_child  \
    window_insertion_point       focused       \
    window_zoom_persist          on            \
    window_shadow                on            \
    window_animation_duration    0.2           \
    window_animation_easing      ease_out_circ \
    window_opacity_duration      0.15          \
    active_window_opacity        1.0           \
    normal_window_opacity        0.92          \
    window_opacity               on            \
    insert_feedback_color        0xff9dd274    \
    split_ratio                  0.52          \
    split_type                   auto          \
    auto_balance                 off           \
    top_padding                  10            \
    bottom_padding               10            \
    left_padding                 10            \
    right_padding                10            \
    window_gap                   06            \
    layout                       bsp           \
    mouse_modifier               fn            \
    mouse_action1                move          \
    mouse_action2                resize        \
    mouse_drop_action            swap

# ── Float rules ──────────────────────────────────────────────────────────────

# System
yabai -m rule --add app="^System Settings$"           manage=off
yabai -m rule --add app="^System Information$"        manage=off
yabai -m rule --add app="^System Preferences$"        manage=off
yabai -m rule --add app="^Activity Monitor$"          manage=off
yabai -m rule --add app="^Archive Utility$"           manage=off
yabai -m rule --add app="^Console$"                   manage=off
yabai -m rule --add app="^Disk Utility$"              manage=off
yabai -m rule --add app="^Font Book$"                 manage=off
yabai -m rule --add app="^Keychain Access$"           manage=off
yabai -m rule --add app="^Migration Assistant$"       manage=off
yabai -m rule --add app="^Screenshot$"                manage=off
yabai -m rule --add app="^Finder$"                    manage=off
yabai -m rule --add app="^Calculator$"                manage=off

# Dialogs and preference panels (use regex anchors to avoid over-matching)
yabai -m rule --add title="^Preferences$"             manage=off
yabai -m rule --add title="^Settings$"                manage=off
yabai -m rule --add title="^(Open|Save|Print).*"      manage=off

# Helium (floating PiP browser — keep above all windows, visible on every space)
yabai -m rule --add app="^Helium$"                    manage=off sticky=on layer=above

# Apps
yabai -m rule --add app="^Spotify$"                   manage=off
yabai -m rule --add app="^Discord$"                   manage=off
yabai -m rule --add app="^Alfred$"                    manage=off
yabai -m rule --add app="^Raycast$"                   manage=off
yabai -m rule --add app="^1Password$"                 manage=off
yabai -m rule --add app="^Vimac$"                     manage=off
yabai -m rule --add app="^zoom.us$"                   manage=off
yabai -m rule --add app="^CleanMyMac$"                manage=off

echo "yabai configuration loaded.."
